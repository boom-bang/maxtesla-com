---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const fmt = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<BaseLayout title="Posts" description="Notes, essays, and shipping stories.">
  <main class="mx-auto max-w-3xl px-6 pt-32 pb-20">
    <header class="mb-16">
      <h1
        class="font-display text-5xl font-bold tracking-tight text-[color:var(--site-fg)] md:text-6xl"
      >
        posts
      </h1>
      <p
        class="mt-3 font-sans text-base text-[color:var(--site-muted-fg)] md:text-lg"
      >
        notes, essays, and shipping stories.
      </p>
    </header>

    {
      posts.length === 0 ? (
        <p class="font-mono text-sm text-[color:var(--site-muted)]">
          nothing published yet.
        </p>
      ) : (
        <ul class="divide-y divide-[color:var(--site-border)]">
          {posts.map((post) => (
            <li>
              <a
                href={`/posts/${post.id}`}
                class="group flex flex-col gap-1 py-6 transition-colors hover:bg-[color:var(--site-border)]/20 md:flex-row md:items-baseline md:gap-6 md:px-2"
              >
                <time
                  datetime={post.data.date.toISOString()}
                  class="shrink-0 font-mono text-xs text-[color:var(--site-muted)] md:w-24"
                >
                  {fmt.format(post.data.date)}
                </time>
                <div class="min-w-0 flex-1">
                  <h2 class="font-display text-xl font-semibold tracking-tight text-[color:var(--site-fg)] transition-colors group-hover:text-[color:var(--site-muted-fg)] md:text-2xl">
                    {post.data.title}
                  </h2>
                  {post.data.summary && (
                    <p class="mt-1 text-sm text-[color:var(--site-muted-fg)] md:text-base">
                      {post.data.summary}
                    </p>
                  )}
                </div>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</BaseLayout>
